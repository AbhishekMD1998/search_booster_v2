// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductAudit {
  id                String   @id @default(cuid())
  userId            String                        // Clerk user ID
  url               String
  pageTitle         String?
  robotsStatus      String                        // "PASSED" | "BLOCKED" | "NOT_FOUND"
  hasProductSchema  Boolean  @default(false)
  aiScore           Int?                          // 1-100
  weaknesses        String[]                      // up to 3 bullet points
  rewrittenDesc     String?  @db.Text
  rawSchemaSnippet  String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
  @@map("product_audits")
}
